generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Establishment {
  id                  String            @id @default(cuid())
  name                String
  slug                String            @unique
  email               String            @unique
  password            String
  phone               String
  logo                String?
  cover               String?
  description         String?
  address             String?
  category            String?
  instagramUrl        String?
  primaryColor        String            @default("#16a34a")
  backgroundColor     String            @default("#ffffff")
  textColor           String            @default("#1a1a2e")
  headerColor         String            @default("#ffffff")
  colorsPublished     Boolean           @default(false)
  businessHours       String?           @default("[{\"day\":\" Segunda\",\"open\":\"09:00\",\"close\":\"22:00\",\"active\":true},{\"day\":\"Terça\",\"open\":\"09:00\",\"close\":\"22:00\",\"active\":true},{\"day\":\"Quarta\",\"open\":\"09:00\",\"close\":\"22:00\",\"active\":true},{\"day\":\"Quinta\",\"open\":\"09:00\",\"close\":\"22:00\",\"active\":true},{\"day\":\"Sexta\",\"open\":\"09:00\",\"close\":\"22:00\",\"active\":true},{\"day\":\"Sábado\",\"open\":\"09:00\",\"close\":\"23:00\",\"active\":true},{\"day\":\"Domingo\",\"open\":\"00:00\",\"close\":\"00:00\",\"active\":false}]")
  loyaltyConfig       String?           @default("{\"enabled\":false,\"pointsPerReal\":1,\"redeemPoints\":100,\"redeemDiscount\":10}")
  isActive            Boolean           @default(true)
  asaasApiKey         String?
  asaasWalletId       String?
  paymentConfig       String            @default("{\"online\":true,\"delivery\":true,\"pickup\":true}")
  orderConfig         String            @default("{\"delivery\":true,\"pickup\":true}")
  deliveryFeeType     String            @default("free")
  deliveryFeeAmount   Float?            @default(0)
  deliveryFreeAbove   Float?            @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  pickupMessage       String?
  deliveryMessage     String?
  confirmationTitle   String?
  confirmationImage   String?
  closedSub           String?
  closedTitle         String?
  defaultTheme        String            @default("dark")
  expenseCategories   String            @default("[\"fixa\",\"variavel\",\"motoboy\",\"insumo\",\"salario\",\"aluguel\",\"energia\",\"agua\",\"internet\",\"imposto\",\"manutencao\",\"marketing\",\"outro\"]")
  asaasCustomerId     String?
  asaasSubscriptionId String?
  nextPaymentAt       DateTime?
  tableCount          Int               @default(10)
  subscriptionPlan    String?           @default("starter")
  subscriptionStatus  String            @default("trial")
  trialEndsAt         DateTime?
  trialStartsAt       DateTime?
  cashRegisters       CashRegister[]
  categories          Category[]
  coupons             Coupon[]
  customers           Customer[]
  deliveryPayments    DeliveryPayment[]
  deliveryPeople      DeliveryPerson[]
  expenses            Expense[]
  orders              Order[]
  paymentRequests     PaymentRequest[]
  partialPayments     PartialPayment[]
  products            Product[]
  reviews             Review[]
  stockCategories     StockCategory[]
  stockItems          StockItem[]
  suppliers           Supplier[]
  users               User[]
}

model Customer {
  id              String        @id @default(cuid())
  name            String?
  phone           String        @unique
  cpf             String?
  address         String?
  cep             String?
  totalOrders     Int           @default(0)
  totalSpent      Float         @default(0)
  loyaltyPoints   Int           @default(0)
  lastOrderAt     DateTime?
  establishmentId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  orders          Order[]
  reviews         Review[]

  @@index([establishmentId, phone])
}

model DeliveryPerson {
  id              String            @id @default(cuid())
  name            String
  phone           String
  token           String            @unique
  establishmentId String
  userId          String?           @unique
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  payments        DeliveryPayment[]
  establishment   Establishment     @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id])
  orders          Order[]
}

model Category {
  id              String        @id @default(cuid())
  name            String
  order           Int           @default(0)
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  products        Product[]
}

model Product {
  id              String             @id @default(cuid())
  name            String
  description     String?
  price           Float
  image           String?
  isAvailable     Boolean            @default(true)
  sendToPrep      Boolean            @default(false)
  order           Int                @default(0)
  badge           String?
  categoryId      String
  establishmentId String
  stockItemId     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  category        Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  establishment   Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  stockItem       StockItem?         @relation(fields: [stockItemId], references: [id])
  stockLinks      ProductStockLink[]
}

model Order {
  id                String          @id @default(cuid())
  orderNumber       Int?
  establishmentId   String
  customerId        String?
  customerName      String
  customerPhone     String?
  customerAddress   String?
  orderType         String          @default("delivery")
  paymentMethod     String          @default("online")
  items             String
  total             Float
  deliveryFee       Float           @default(0)
  status            String          @default("pending")
  paymentId         String?
  paymentLink       String?
  paymentStatus     String          @default("pending")
  notes             String?
  method            String          @default("site")
  tableNumber       Int?
  deliveryPerson    String?
  deliveryPersonId  String?
  couponId          String?
  trackingToken     String?         @unique
  assignedAt        DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  coupon            Coupon?         @relation(fields: [couponId], references: [id])
  customer          Customer?       @relation(fields: [customerId], references: [id])
  deliveryPersonRel DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id])
  establishment     Establishment   @relation(fields: [establishmentId], references: [id])
  messages          OrderMessage[]

  @@unique([establishmentId, orderNumber])
  @@index([establishmentId, createdAt])
  @@index([establishmentId, status])
  @@index([establishmentId, tableNumber, orderType])
  @@index([establishmentId, orderType, status])
  @@index([establishmentId, deliveryPersonId])
  @@index([paymentId])
}

model StockCategory {
  id              String        @id @default(cuid())
  name            String
  order           Int           @default(0)
  establishmentId String
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  items           StockItem[]
}

model StockItem {
  id              String             @id @default(cuid())
  name            String
  unit            String             @default("un")
  quantity        Float              @default(0)
  minQuantity     Float              @default(0)
  unitCost        Float              @default(0)
  supplier        String?
  supplierId      String?
  categoryId      String
  establishmentId String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  products        Product[]
  productLinks    ProductStockLink[]
  category        StockCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  establishment   Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  supplierRef     Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements       StockMovement[]
}

model Supplier {
  id              String        @id @default(cuid())
  name            String
  phone           String?
  cnpj            String?
  email           String?
  notes           String?
  establishmentId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  stockItems      StockItem[]
}

model StockMovement {
  id        String    @id @default(cuid())
  type      String
  quantity  Float
  unitCost  Float?
  notes     String?
  itemId    String
  createdAt DateTime  @default(now())
  item      StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

model ProductStockLink {
  id          String    @id @default(cuid())
  productId   String
  stockItemId String
  quantity    Float
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([productId, stockItemId])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  role                String               @default("atendente")
  permissions         String               @default("[\"caixa\"]")
  canCloseRegister    Boolean              @default(false)
  isActive            Boolean              @default(true)
  mustChangePassword  Boolean              @default(false)
  establishmentId     String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  paidDeliveries      DeliveryPayment[]
  deliveryPerson      DeliveryPerson?
  passwordResetTokens PasswordResetToken[]
  establishment       Establishment        @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryPayment {
  id               String         @id @default(cuid())
  amount           Float
  period           String         @default("manual")
  notes            String?
  deliveryPersonId String
  paidById         String?
  establishmentId  String
  createdAt        DateTime       @default(now())
  deliveryPerson   DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  establishment    Establishment  @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  paidBy           User?          @relation(fields: [paidById], references: [id])

  @@index([establishmentId, createdAt])
}

model Coupon {
  id              String        @id @default(cuid())
  code            String
  type            String        @default("percent")
  value           Float
  minOrder        Float         @default(0)
  maxUses         Int?
  usedCount       Int           @default(0)
  active          Boolean       @default(true)
  expiresAt       DateTime?
  establishmentId String
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@unique([code, establishmentId])
}

model CashRegister {
  id              String         @id @default(cuid())
  openingAmount   Float
  closingAmount   Float?
  expectedAmount  Float?
  status          String         @default("open")
  notes           String?
  currentUserId   String?
  establishmentId String
  createdAt       DateTime       @default(now())
  closedAt        DateTime?
  movements       CashMovement[]
  establishment   Establishment  @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  transfers       CashTransfer[]

  @@index([establishmentId, status])
  @@index([establishmentId, createdAt])
}

model CashTransfer {
  id             String       @id @default(cuid())
  cashRegisterId String
  fromUserId     String
  toUserId       String
  amount         Float
  notes          String?
  createdAt      DateTime     @default(now())
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
}

model CashMovement {
  id             String       @id @default(cuid())
  type           String
  amount         Float
  description    String?
  paymentMethod  String?
  orderId        String?
  cashRegisterId String
  createdAt      DateTime     @default(now())
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
}

model Expense {
  id              String        @id @default(cuid())
  description     String
  amount          Float
  category        String        @default("variavel")
  type            String        @default("lancamento")
  paymentMethod   String        @default("dinheiro")
  isRecurring     Boolean       @default(false)
  recurrenceFreq  String?
  recurrenceStart DateTime?
  recurrenceEnd   DateTime?
  receiptUrl      String?
  date            DateTime?
  dueDate         DateTime?
  cashRegisterId  String?
  establishmentId String
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId, createdAt])
  @@index([establishmentId, type])
  @@index([establishmentId, dueDate])
}

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  sender    String   @default("customer")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PaymentRequest {
  id              String        @id @default(cuid())
  tableNumber     Int
  establishmentId String
  status          String        @default("pending")
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  resolvedAt      DateTime?
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId, status])
}

model PartialPayment {
  id              String        @id @default(cuid())
  tableNumber     Int
  establishmentId String
  amount          Float
  paymentMethod   String
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId, tableNumber])
}

model Review {
  id              String        @id @default(cuid())
  rating          Int
  comment         String?
  customerId      String?
  tableNumber     Int?
  orderId         String?
  establishmentId String
  createdAt       DateTime      @default(now())
  customer        Customer?     @relation(fields: [customerId], references: [id])
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId, createdAt])
  @@index([establishmentId, rating])
}
